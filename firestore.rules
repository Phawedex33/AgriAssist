rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Global Helpers
    function isSignedIn() { 
      return request.auth != null && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // 2. Entity Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'language', 'primaryCrop', 'createdAt', 'updatedAt'])
             && data.uid == request.auth.uid
             && data.language in ['English', 'Swahili']
             && data.primaryCrop is string && data.primaryCrop.size() <= 100
             && (!data.keys().contains('location') || (
                data.location.keys().hasAll(['lat', 'lon']) &&
                data.location.lat is number &&
                data.location.lon is number
             ));
    }

    function isValidDiagnosis(data) {
      return data.keys().hasAll(['userId', 'disease', 'treatment', 'timestamp'])
             && data.userId == request.auth.uid
             && data.disease is string && data.disease.size() <= 200
             && data.treatment is string && data.treatment.size() <= 2000
             && data.timestamp == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'role', 'content', 'timestamp'])
             && data.userId == request.auth.uid
             && data.role in ['user', 'assistant']
             && data.content is string && data.content.size() <= 5000
             && data.timestamp == request.time;
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['userId', 'cropName', 'frequency', 'preferredTime', 'createdAt'])
             && data.userId == request.auth.uid
             && data.cropName is string && data.cropName.size() <= 100
             && data.frequency in ['daily', 'twice-daily', 'alternate-days', 'weekly']
             && data.preferredTime is string && data.preferredTime.matches('^[0-9]{2}:[0-9]{2}$');
    }

    // 3. Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming())
                       && incoming().createdAt == request.time
                       && incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming())
                       && incoming().uid == existing().uid
                       && incoming().createdAt == existing().createdAt
                       && incoming().updatedAt == request.time
                       && (incoming().diff(existing()).affectedKeys().hasOnly(['language', 'primaryCrop', 'location', 'updatedAt']));
      
      // Subcollections
      match /diagnoses/{diagnosisId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId) && resource.data.userId == request.auth.uid && isValidId(diagnosisId);
        allow create: if isOwner(userId) && isValidId(diagnosisId) && isValidDiagnosis(incoming());
        allow update, delete: if false; // History is immutable for transparency
      }

      match /messages/{messageId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(messageId) && isValidMessage(incoming());
        allow get, update, delete: if false;
      }

      match /schedules/{scheduleId} {
        allow list: if isOwner(userId) && (resource == null || resource.data.userId == request.auth.uid);
        allow get: if isOwner(userId) && resource.data.userId == request.auth.uid && isValidId(scheduleId);
        allow create: if isOwner(userId) && isValidId(scheduleId) && isValidSchedule(incoming())
                         && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidId(scheduleId) && isValidSchedule(incoming())
                         && incoming().createdAt == existing().createdAt
                         && (incoming().diff(existing()).affectedKeys().hasOnly(['cropName', 'frequency', 'preferredTime', 'notes']));
        allow delete: if isOwner(userId) && existing().userId == request.auth.uid;
      }
    }
  }
}
